    "Biografia": {
      "Passado": "Heremita",
      "Motivacao": "Explorar Culturas Diferentes",
      "Genero": "M",
      "Idade": "63",
      "Naturalidade": "[[Floresta da Ordem]]",
      "Altura": "1.79m",
      "Peso": "76kg",
      "Ideais": [
        "Quem não é curioso, é suspeito",
        "Proteção de culturas diferentes"
      ],
      "Desprezos": [
        "Idosos Sedentários",
